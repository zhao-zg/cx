                      "level": "a",
                      "title": "神而人者住在人而神者的里面。",
                      "content": [],
                      "children": []
                    },
                    {
                      "level": "b",
                      "title": "人而神者又住在神而人者的里面。",
                      "content": [],
                      "children": []
                    }
                  ]
                }
              ]
            }
          ]
        }
